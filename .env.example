# ===========================================
# PHASE 1 — WooCommerce as temporary backend
# ===========================================
# Generate keys at:
# https://ahmedmzaliboutique.com/wp-admin/admin.php?page=wc-settings&tab=advanced&section=keys
WC_API_URL=https://ahmedmzaliboutique.com
WC_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WC_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===========================================
# Public site config
# ===========================================
NEXT_PUBLIC_SITE_NAME=Boutique Ahmed Mzali
NEXT_PUBLIC_SITE_URL=https://ahmedmzaliboutique.com
NEXT_PUBLIC_CURRENCY_CODE=TND
NEXT_PUBLIC_CURRENCY_SYMBOL=DT

# ===========================================
# Navex shipping API — https://navex.tn
# ===========================================
NAVEX_API_BASE=https://app.navex.tn
NAVEX_TOKEN_ADD=
NAVEX_TOKEN_GET=
NAVEX_TOKEN_DELETE=
# Orders are auto-pushed to Navex when delivery company contains this string (case-insensitive)
NAVEX_AUTO_PUSH_LABEL=navex

# ===========================================
# First Delivery Group API — https://www.firstdeliverygroup.com
# ===========================================
FIRST_DELIVERY_API_BASE=https://www.firstdeliverygroup.com/api/v2
FIRST_DELIVERY_TOKEN=
# Auto-push when delivery company name contains this string (case-insensitive)
FIRST_DELIVERY_AUTO_PUSH_LABEL=firstdelivery


# ===========================================
# Admin auth
# ===========================================
ADMIN_PASSWORD=change-me

# WordPress application password — for image uploads to /wp-json/wp/v2/media.
# Generate at /wp-admin/profile.php → Mots de passe d'application
WP_ADMIN_USER=
WP_APP_PASSWORD=
SESSION_SECRET=change-me-32-bytes-min

# ===========================================
# Phase 2 — placeholders (not used yet)
# ===========================================
